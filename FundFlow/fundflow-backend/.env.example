# ---- Anakin (FundFlow Audit) ----
ANAKIN_API_KEY=
ANAKIN_API_BASE=https://api.anakin.io/v1
ANAKIN_TOTAL_CREDIT_BUDGET=300
ANAKIN_MAX_CREDITS_PER_AUDIT=8
ANAKIN_MAX_WIRE_CREDITS_PER_CALL=3
ANAKIN_CACHE_TTL_HOURS=168
ANAKIN_SEARCH_CACHE_TTL_HOURS=720

# Optional Wire action overrides (logical purpose -> action id)
WIRE_ACTION_FUND_PROFILE=
WIRE_ACTION_FUND_HOLDINGS=
WIRE_ACTION_MANAGER_NEWS=
WIRE_ACTION_SECURITY_PROFILE=
WIRE_ACTION_MARKET_CAP=

# ---- LLMs ----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GROQ_API_KEY=
OPENAI_API_KEY=

# ---- ElevenLabs ----
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_TTS_MODEL=eleven_turbo_v2_5

# ---- Runtime (persistence is in-memory; no external database) ----
ALLOWED_ORIGINS=*
PORT=8080

# ---- Demo ----
FUNDFLOW_DEMO_MODE=true
